#!/usr/bin/env python3

import os, sys, json, argparse, tempfile, time, threading, subprocess
from datetime import datetime
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, wait

class Colors:
    GREEN, RED, YELLOW, NC = '\033[0;32m', '\033[0;31m', '\033[1;33m', '\033[0m'

def format_time(seconds):
    """Converts seconds into a MM:SS string."""
    m, s = divmod(int(seconds), 60)
    return f"{m:02d}:{s:02d}"

class TerminalUI:
    """Encapsulates all thread-safe terminal rendering logic."""
    def __init__(self, test_files, is_tty):
        self.is_tty = is_tty
        self.total = len(test_files)
        self.line_map = {str(t): i for i, t in enumerate(test_files)}
        self.lock = threading.Lock()

    def init_display(self, test_files):
        if not self.is_tty: return
        for t in test_files:
            print(f"[    ] --:-- {t}")
        print() # Space for progress bar
        sys.stdout.flush()

    def update_test(self, test_path, status, duration="--:--"):
        if not self.is_tty: return
        lines_up = (self.total - self.line_map[test_path]) + 1
        with self.lock:
            # Move up, clear line, write status, move back down
            print(f"\033[{lines_up}A\r\033[K{status} {duration} {test_path}\033[{lines_up}B", end="", flush=True)

    def update_progress(self, completed, elapsed):
        if not self.is_tty: return
        pct = int((completed / self.total) * 100) if self.total else 100
        fill = int(20 * completed // self.total) if self.total else 20
        bar = '#' * fill + '-' * (20 - fill)
        with self.lock:
            print(f"\r\033[KProgress: [{bar}] {pct}% ({completed}/{self.total}) | {format_time(elapsed)}", end="", flush=True)

    def clear_progress(self):
        if not self.is_tty: return
        with self.lock:
            print("\r\033[K", end="", flush=True)

def run_test(test_file, env, stream_output=False):
    """Executes a single test script in an isolated temporary directory."""
    test_env = env.copy()
    
    with tempfile.TemporaryDirectory(prefix="virt_validate_") as temp_dir:
        temp_path = Path(temp_dir)
        
        # Sandbox mirroring
        for item in test_file.parent.iterdir():
            if item.is_file():
                (temp_path / item.name).symlink_to(item.absolute())
        
        with tempfile.TemporaryFile() as report_f:
            fd = report_f.fileno()
            os.set_inheritable(fd, True)
            test_env["TEST_REPORT_FD"] = str(fd)
            
            start_ts = time.monotonic()
            process = subprocess.Popen(
                ["bash", "-xe", test_file.name],
                cwd=temp_path, env=test_env,
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, pass_fds=(fd,)
            )
            
            log_lines = []
            # Iterate process output live for accurate timestamps
            for line in process.stdout:
                ts_line = f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S.%f')[:-3]}] {line.rstrip()}"
                log_lines.append(ts_line)
                if stream_output:
                    print(ts_line)
            
            process.wait()
            duration = time.monotonic() - start_ts
            
            report_f.seek(0)
            report_messages = report_f.read().decode('utf-8').splitlines()
    
    return {
        "testpath": str(test_file),
        "success": process.returncode == 0,
        "duration": duration,
        "report_messages": report_messages,
        "log": log_lines,
        "errors": log_lines if process.returncode != 0 else [],
        "warnings": [line for line in log_lines if "warn" in line.lower()]
    }

def execute_task(test_file, env, ui, stream_output):
    """Wrapper that updates the terminal status before and after execution."""
    ui.update_test(str(test_file), "[    ]")
    result = run_test(test_file, env, stream_output)
    
    status_str = f"[{Colors.GREEN}PASS{Colors.NC}]" if result["success"] else f"[{Colors.RED}FAIL{Colors.NC}]"
    ui.update_test(str(test_file), status_str, format_time(result["duration"]))
    
    return result

def print_details(results, verbose, skip_log_print=False):
    """Prints the expanded logs and reports for relevant tests."""
    if not any(not r["success"] or r["report_messages"] for r in results) and not verbose:
        return

    print(f"\n{'='*20} DETAILS {'='*20}")
    for r in results:
        if not r["success"] or r["report_messages"] or verbose:
            color = Colors.GREEN if r["success"] else Colors.RED
            print(f"\n[{color}{'PASS' if r['success'] else 'FAIL'}{Colors.NC}] {format_time(r['duration'])} {r['testpath']}")
            
            for msg in r["report_messages"]:
                c = Colors.RED if msg.startswith("FAIL:") else ""
                print(f"    {c}-> {msg}{Colors.NC if c else ''}")
                
            if r["log"] and (not r["success"] or verbose) and not skip_log_print:
                print("    --- Test Output ---")
                for line in r["log"]: print(f"    {line}")

def main():
    parser = argparse.ArgumentParser(description="Simple test runner for virt-cluster-validate checks.")
    parser.add_argument("-o", "--output", choices=["json", "human"], default="human", help="Output format (default: human)")
    parser.add_argument("-v", "--verbose", action="store_true", help="Show test output in human-readable mode")
    parser.add_argument("-f", "--fail-fast", nargs="?", const=1, type=int, metavar="N", help="Stop execution after N failures")
    parser.add_argument("-s", "--select", metavar="PATH", help="Only run the specific test file provided (e.g. checks.d/10-openshift.d/10-nodes.d/test.sh)")
    args = parser.parse_args()

    # 1. Environment & Discovery
    env = {**os.environ, "PATH": f"{os.path.abspath('bin')}{os.pathsep}{os.environ.get('PATH', '')}"}
    test_files = sorted(Path("checks.d").rglob("test*.sh"))
    
    if args.select:
        test_files = [t for t in test_files if str(t) == args.select]
        
    if not test_files:
        print("No tests found.")
        sys.exit(0)

    # 2. UI Initialization
    stream_output = bool(args.select and args.verbose and args.output == "human")
    # Disable the complex Terminal UI if we are in raw streaming mode
    is_tty = args.output == "human" and sys.stdout.isatty() and not stream_output
    
    ui = TerminalUI(test_files, is_tty)
    ui.init_display(test_files)
    
    # 3. Execution
    workers = int(os.environ.get("NUM_CONCURRENT_TESTS", os.cpu_count() or 4))
    results = []
    failed_count = 0
    start_time = time.monotonic()

    with ThreadPoolExecutor(max_workers=workers) as executor:
        futures = {executor.submit(execute_task, t, env, ui, stream_output): t for t in test_files}
        pending = set(futures.keys())
        
        while pending:
            done, pending = wait(pending, timeout=1.0)
            
            for f in done:
                if not f.cancelled():
                    r = f.result()
                    results.append(r)
                    if not r["success"]: failed_count += 1

            # Fail-Fast Trigger
            if args.fail_fast and failed_count >= args.fail_fast:
                for p in pending: p.cancel()

            ui.update_progress(len(results), time.monotonic() - start_time)

    ui.clear_progress()
    
    # 4. Mark Skipped Tests
    executed_paths = {r["testpath"] for r in results}
    for t in (str(tf) for tf in test_files if str(tf) not in executed_paths):
        ui.update_test(t, f"[{Colors.YELLOW}SKIP{Colors.NC}]")

    # 5. Output Results
    results.sort(key=lambda x: x["testpath"])
    
    # Unified Summary Calculation
    passed = sum(1 for r in results if r["success"])
    failed = len(results) - passed
    skipped = len(test_files) - len(results)
    
    summary = f"Passed: {passed}, Failed: {failed}" + (f", Skipped: {skipped}" if skipped else "") + f", Total: {len(test_files)}"
    
    if args.output == "human":
        # Do not print the log blob a second time if we already streamed it live
        print_details(results, args.verbose, skip_log_print=stream_output)
        print("-" * 40)
        print(summary)
        print(f"Total time: {format_time(time.monotonic() - start_time)}")
    else:
        print(json.dumps({"summary": summary, "results": results}, indent=2))
        
    sys.exit(1 if failed_count > 0 else 0)

if __name__ == "__main__":
    main()
