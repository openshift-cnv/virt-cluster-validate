import os, sys, json, argparse, tempfile, time, threading, subprocess, signal, random, shutil
from datetime import datetime
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, wait

class Colors:
    GREEN, RED, YELLOW, NC = '\033[0;32m', '\033[0;31m', '\033[1;33m', '\033[0m'

def format_time(seconds):
    """Converts seconds into a MM:SS string."""
    m, s = divmod(int(seconds), 60)
    return f"{m:02d}:{s:02d}"

def parse_timespan(value):
    """Parses a human-friendly timespan string (e.g. 2m, 45s, 180) into integer seconds."""
    if value.isdigit():
        return int(value)
    value = value.lower().strip()
    if value.endswith('m'):
        return int(value[:-1]) * 60
    if value.endswith('s'):
        return int(value[:-1])
    raise argparse.ArgumentTypeError(f"Invalid timespan: '{value}'. Use format like '2m', '45s', or '180'.")

class TerminalUI:
    """Encapsulates all thread-safe terminal rendering logic."""
    def __init__(self, test_files, is_tty):
        self.is_tty = is_tty
        self.total = len(test_files)
        self.line_map = {str(t): i for i, t in enumerate(test_files)}
        self.lock = threading.Lock()
        self.term_width = shutil.get_terminal_size((80, 24)).columns

    def _truncate(self, text, max_len):
        """Truncate text to fit within max_len, adding ellipsis if needed."""
        if len(text) <= max_len:
            return text
        return text[:max_len-3] + "..."

    def init_display(self, test_files):
        if not self.is_tty: return
        # Reserve space for "[WARN] MM:SS " prefix (16 chars)
        path_max = self.term_width - 16
        for t in test_files:
            truncated = self._truncate(str(t), path_max)
            print(f"[    ] --:-- {truncated}")
        print() # Space for progress bar
        sys.stdout.flush()

    def update_test(self, test_path, status, duration="--:--"):
        if not self.is_tty: return
        lines_up = (self.total - self.line_map[test_path]) + 1
        # Reserve space for status and duration
        path_max = self.term_width - 16
        truncated = self._truncate(test_path, path_max)
        with self.lock:
            # Move up, clear line, write status, move back down
            print(f"\033[{lines_up}A\r\033[K{status} {duration} {truncated}\033[{lines_up}B", end="", flush=True)

    def update_progress(self, completed, elapsed):
        if not self.is_tty: return
        pct = int((completed / self.total) * 100) if self.total else 100
        fill = int(20 * completed // self.total) if self.total else 20
        bar = '#' * fill + '-' * (20 - fill)
        progress_line = f"Progress: [{bar}] {pct}% ({completed}/{self.total}) | {format_time(elapsed)}"
        truncated = self._truncate(progress_line, self.term_width)
        with self.lock:
            print(f"\r\033[K{truncated}", end="", flush=True)

    def clear_progress(self):
        if not self.is_tty: return
        with self.lock:
            print("\r\033[K", end="", flush=True)

def simulate_test(test_file, stream_output=False, timeout_secs=180):
    """Simulates a test execution (random runtimes up to 6s, random pass/fail)."""
    sleep_time = random.uniform(0.5, 6.0)
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S.%f")[:-3]
    
    # Simulate a timeout if the randomly generated sleep time is longer than the actual timeout
    if sleep_time > timeout_secs:
        time.sleep(timeout_secs)
        log_lines = [f"[{ts}] TIMEOUT: Test exceeded {timeout_secs} seconds and was killed."]
        if stream_output:
            print(log_lines[0])
        return {
            "testpath": str(test_file),
            "success": False,
            "cancelled": True,
            "duration": timeout_secs,
            "report_messages": [],
            "log": log_lines,
            "errors": log_lines,
            "warnings": []
        }
        
    time.sleep(sleep_time)
    # Randomize success, but heavily bias toward PASS for a more realistic dashboard
    success = random.choice([True, True, True, False]) 
    
    log_lines = [f"[{ts}] Executing simulated test..."]
    if stream_output:
        print(log_lines[0])
        
    if success:
        if random.random() > 0.8:
            has_warnings = True
            report_messages = [f"WARN: Simulated warning in {test_file.name}"]
        else:
            has_warnings = False
            report_messages = [f"INFO: Successfully simulated execution of {test_file.name}"]
    else:
        has_warnings = False
        report_messages = [f"FAIL: Simulated failure occurred in {test_file.name}"]
        
    return {
        "testpath": str(test_file),
        "success": success,
        "has_warnings": has_warnings,
        "cancelled": False,
        "duration": sleep_time,
        "report_messages": report_messages,
        "log": log_lines,
        "errors": log_lines if not success else [],
        "warnings": []
    }

def run_test(test_file, env, stream_output=False, timeout_secs=180):
    """Executes a single test script in an isolated temporary directory with a timeout."""
    test_env = env.copy()
    
    with tempfile.TemporaryDirectory(prefix="virt_validate_") as temp_dir:
        temp_path = Path(temp_dir)
        
        # Sandbox mirroring
        for item in test_file.parent.iterdir():
            if item.is_file():
                (temp_path / item.name).symlink_to(item.absolute())
        
        with tempfile.TemporaryFile() as report_f:
            fd = report_f.fileno()
            os.set_inheritable(fd, True)
            test_env["TEST_REPORT_FD"] = str(fd)
            
            start_ts = time.monotonic()
            
            process = subprocess.Popen(
                ["bash", "-xe", test_file.name],
                cwd=temp_path, env=test_env,
                stdin=subprocess.DEVNULL,
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, pass_fds=(fd,),
                start_new_session=True
            )

            timed_out = [False]
            GRACE_PERIOD = 10
            def kill_proc():
                timed_out[0] = True
                try:
                    pgid = os.getpgid(process.pid)
                    os.killpg(pgid, signal.SIGTERM)
                    try:
                        process.wait(timeout=GRACE_PERIOD)
                    except subprocess.TimeoutExpired:
                        os.killpg(pgid, signal.SIGKILL)
                except Exception:
                    pass

            timer = threading.Timer(timeout_secs, kill_proc)
            timer.start()
            
            log_lines = []
            try:
                # Iterate process output live for accurate timestamps
                for line in process.stdout:
                    ts_line = f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S.%f')[:-3]}] {line.rstrip()}"
                    log_lines.append(ts_line)
                    if stream_output:
                        print(ts_line)
            finally:
                timer.cancel()
            
            process.wait()
            duration = time.monotonic() - start_ts
            
            skipped = False
            if timed_out[0]:
                ts_line = f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S.%f')[:-3]}] TIMEOUT: Test exceeded {timeout_secs} seconds and was killed."
                log_lines.append(ts_line)
                if stream_output:
                    print(ts_line)
                success = False
            else:
                success = process.returncode == 0
                skipped = process.returncode == 77

            report_f.seek(0)
            report_messages = report_f.read().decode('utf-8').splitlines()

            if not success and not skipped and not report_messages:
                if timed_out[0]:
                    report_messages = [f"FAIL: Test exceeded {timeout_secs}s timeout and was killed"]
                else:
                    last_lines = [l.split("] ", 1)[-1] for l in log_lines[-3:] if "] +" not in l]
                    hint = last_lines[-1] if last_lines else f"exit code {process.returncode}"
                    report_messages = [f"FAIL: {hint}"]

    has_warnings = any(msg.startswith("WARN:") for msg in report_messages)

    return {
        "testpath": str(test_file),
        "success": success or skipped,
        "skipped": skipped,
        "has_warnings": has_warnings,
        "cancelled": timed_out[0],
        "duration": duration,
        "report_messages": report_messages,
        "log": log_lines,
        "errors": log_lines if not success else [],
        "warnings": [line for line in log_lines if "warn" in line.lower()]
    }

def execute_task(test_file, env, ui, stream_output, timeout_secs, mock):
    """Wrapper that updates the terminal status before and after execution."""
    ui.update_test(str(test_file), "[    ]")
    
    if mock:
        result = simulate_test(test_file, stream_output, timeout_secs)
    else:
        result = run_test(test_file, env, stream_output, timeout_secs)
    
    if result.get("cancelled"):
        status_str = f"[{Colors.YELLOW}----{Colors.NC}]"
    elif result.get("skipped"):
        status_str = f"[{Colors.YELLOW}SKIP{Colors.NC}]"
    elif not result["success"]:
        status_str = f"[{Colors.RED}FAIL{Colors.NC}]"
    elif result.get("has_warnings"):
        status_str = f"[{Colors.YELLOW}WARN{Colors.NC}]"
    else:
        status_str = f"[{Colors.GREEN}PASS{Colors.NC}]"
    
    ui.update_test(str(test_file), status_str, format_time(result["duration"]))
    
    return result

def print_details(results, verbose, skip_log_print=False):
    """Prints the expanded logs and reports for relevant tests."""
    if not verbose:
        return

    print(f"\n{'='*20} DETAILS {'='*20}")
    for r in results:
        # -v (verbose=1): show failed/warned checks only
        # -vv (verbose>=2): show all checks
        show_this_test = False
        if verbose >= 2:
            show_this_test = True
        elif verbose == 1:
            show_this_test = not r["success"] or r.get("has_warnings")

        if show_this_test:
            if r.get("cancelled"):
                status_block = "[----]"
            elif not r["success"]:
                status_block = "[FAIL]"
            elif r.get("has_warnings"):
                status_block = "[WARN]"
            else:
                status_block = "[PASS]"
            
            print(f"\n{status_block} {format_time(r['duration'])} {r['testpath']}")
            
            # Print specific pass_with / fail_with messages
            for msg in r["report_messages"]:
                if msg.startswith("FAIL:"):
                    c = Colors.RED
                elif msg.startswith("WARN:"):
                    c = Colors.YELLOW
                else:
                    c = ""
                print(f"    {c}-> {msg}{Colors.NC if c else ''}")

            # Print the log output
            # -v: show logs only for failed tests (not warnings)
            # -vv: show logs for all displayed tests
            show_logs = False
            if verbose >= 2:
                show_logs = True
            elif verbose == 1:
                show_logs = not r["success"]  # Only failures, not warnings

            if r["log"] and not r.get("cancelled") and show_logs and not skip_log_print:
                print("    --- Test Output ---")
                for line in r["log"]: print(f"    {line}")

def check_ai_tool_setup(tool_name, command):
    """Verify AI tool is properly configured by sending a test query."""
    try:
        proc = subprocess.Popen(command, stdin=subprocess.PIPE, stdout=subprocess.PIPE,
                                stderr=subprocess.PIPE, text=True)
        stdout, stderr = proc.communicate(input="Respond with just 'OK' if you can read this.", timeout=10)

        if proc.returncode != 0:
            print(f"{Colors.YELLOW}{tool_name} CLI found but returned an error. Is it configured?{Colors.NC}")
            if stderr:
                print(f"Error: {stderr.strip()[:200]}")
            return False
        return True

    except subprocess.TimeoutExpired:
        proc.kill()
        print(f"{Colors.YELLOW}{tool_name} CLI test timed out. Tool may not be properly configured.{Colors.NC}")
        return False
    except Exception as e:
        print(f"{Colors.YELLOW}{tool_name} CLI test failed: {e}{Colors.NC}")
        return False

def get_test_status(result):
    """Determine human-readable status from test result."""
    if result.get("cancelled"):
        return "CANCELLED (Timeout)"
    elif not result["success"]:
        return "FAILED"
    elif result.get("has_warnings"):
        return "WARNED"
    elif result.get("skipped"):
        return "SKIPPED"
    return "PASSED"

def find_ai_tool():
    """Find and validate an available AI CLI tool (claude or gemini)."""
    for tool_name, command in [("Claude", ["claude"]), ("Gemini", ["gemini", "chat"])]:
        if shutil.which(command[0]) and check_ai_tool_setup(tool_name, command):
            return tool_name, command

    # None found or working
    if not shutil.which("claude") and not shutil.which("gemini"):
        print(f"\n{Colors.YELLOW}AI analysis skipped: neither 'claude' nor 'gemini' CLI found in PATH.{Colors.NC}")
        print(f"Install Claude Code (https://claude.ai/code) or Gemini CLI to enable AI analysis.")
    else:
        print(f"\n{Colors.YELLOW}AI analysis skipped: found CLI tool(s) but none are properly configured.{Colors.NC}")
    return None, None

def build_analysis_document(results, timeout_seconds):
    """Build self-contained analysis document with all test results."""
    failed = sum(1 for r in results if not r["success"] and not r.get("cancelled"))
    cancelled = sum(1 for r in results if r.get("cancelled"))
    warned = sum(1 for r in results if r["success"] and r.get("has_warnings"))
    passed = sum(1 for r in results if r["success"] and not r.get("has_warnings"))

    lines = [
        "=" * 80,
        "OpenShift Cluster Validation - Complete Results",
        "=" * 80,
        f"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}",
        f"Total Checks: {len(results)}",
        f"  - Failed: {failed}",
        f"  - Cancelled (Timeout): {cancelled}",
        f"  - Warned: {warned}",
        f"  - Passed: {passed}",
        "",
        f"NOTE: Test timeout was configured to {timeout_seconds} seconds per test.",
        f"      Tests marked as CANCELLED exceeded this timeout limit.",
        "",
        "=" * 80,
        "ALL CHECKS - DETAILED INFORMATION",
        "=" * 80,
        "",
    ]

    for idx, r in enumerate(results, 1):
        lines.extend([
            f"[{idx}/{len(results)}] {r['testpath']}",
            "-" * 80,
            f"Status: {get_test_status(r)}",
            f"Duration: {format_time(r['duration'])}",
            "",
        ])

        if r["report_messages"]:
            lines.append("Messages:")
            lines.extend(f"  {msg}" for msg in r["report_messages"])
            lines.append("")

        if r["log"]:
            lines.append("Complete Test Output:")
            lines.extend(f"  {line}" for line in r["log"])
        else:
            lines.append("(No log output available)")

        lines.extend(["", "=" * 80, ""])

    lines.extend([
        "",
        "=" * 80,
        "ANALYSIS REQUEST",
        "=" * 80,
        "",
        "Based on the failed checks above, please provide a BRIEF analysis:",
        "",
        "1. ROOT CAUSE (2-3 sentences max)",
        "   - What is wrong with this OpenShift cluster?",
        "   - Common themes across failures?",
        "",
        "2. FIXES (bullet points, commands where applicable)",
        "   - Specific remediation steps for each issue",
        "   - Prioritized by impact",
        "",
        "IMPORTANT: Keep your response SHORT and ACTIONABLE, but do NOT "
        "SPECULATE, base suggestions on EVIDENCE. ALWAYS reference the log file ",
        "you used.",
        "",
        "Limit to essential information only - no lengthy explanations.",
        "",
        "=" * 80,
    ])

    return "\n".join(lines)

def ask_ai_for_conclusion(results, timeout_seconds):
    """Analyze failed checks using Claude or Gemini CLI."""
    if not any(not r["success"] or r.get("cancelled") for r in results):
        return

    ai_tool, ai_command = find_ai_tool()
    if not ai_tool:
        return

    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    analysis_file = f"ai-analysis-{timestamp}.txt"
    print(f"\n{Colors.YELLOW}Preparing analysis file: {analysis_file}{Colors.NC}")

    # Build and write analysis document
    try:
        analysis_content = build_analysis_document(results, timeout_seconds)
        with open(analysis_file, "w") as f:
            f.write(analysis_content)
        print(f"{Colors.GREEN}Analysis file created: {analysis_file}{Colors.NC}")
    except Exception as e:
        print(f"{Colors.RED}Failed to create analysis file: {e}{Colors.NC}")
        return

    # Run AI analysis
    print(f"{Colors.YELLOW}Analyzing with {ai_tool}...{Colors.NC}\n")
    try:
        with open(analysis_file, "r") as f:
            proc = subprocess.Popen(ai_command, stdin=f, stdout=subprocess.PIPE,
                                   stderr=subprocess.PIPE, text=True)
            stdout, stderr = proc.communicate(timeout=120)

        if proc.returncode == 0:
            print(f"{Colors.GREEN}=== AI Analysis ==={Colors.NC}")
            print(stdout)
        else:
            print(f"{Colors.RED}AI analysis failed:{Colors.NC}")
            print(stderr)
    except subprocess.TimeoutExpired:
        proc.kill()
        print(f"{Colors.RED}AI analysis timed out after 120 seconds.{Colors.NC}")
    except Exception as e:
        print(f"{Colors.RED}Error running AI analysis: {e}{Colors.NC}")

    print(f"\n{Colors.YELLOW}Analysis file saved as: {analysis_file}{Colors.NC}")

def main():
    parser = argparse.ArgumentParser(description="Simple test runner for virt-cluster-validate checks.")
    parser.add_argument("-o", "--output", choices=["human", "ctrf"], default="human", help="Output format (default: human)")
    parser.add_argument("-v", "--verbose", action="count", default=0, help="Show test output: -v for failed/warned, -vv for all")
    parser.add_argument("-f", "--fail-fast", nargs="?", const=1, type=int, metavar="N", help="Stop execution after N failures")
    parser.add_argument("-s", "--select", metavar="PATH", help="Only run the specific test file provided (e.g. checks.d/10-openshift.d/10-nodes.d/test.sh)")
    parser.add_argument("--include", metavar="PATTERNS", help="Comma-separated substrings to match; only run tests whose path contains at least one pattern")
    parser.add_argument("--exclude", metavar="PATTERNS", help="Comma-separated substrings to match; skip tests whose path contains any pattern")
    parser.add_argument("--log-dir", metavar="DIR", help="Write per-check log files to this directory")
    parser.add_argument("-t", "--timeout", type=parse_timespan, default="180", metavar="SPAN", help="Timeout for each test (e.g. 3m, 45s, 180; default: 180)")
    parser.add_argument("-c", "--concurrency", type=int, default=os.cpu_count() or 4, metavar="N", help="Number of concurrent tests to run (default: CPU count)")
    parser.add_argument("--ai-analysis", action="store_true", help="Analyze failures with AI (Claude Code or Gemini CLI)")
    args = parser.parse_args()

    # 1. Environment & Discovery
    cache_dir = tempfile.mkdtemp(prefix="virt_validate_cache_")
    env = {**os.environ,
           "PATH": f"{os.path.abspath('bin')}{os.pathsep}{os.environ.get('PATH', '')}",
           "VIRT_VALIDATE_CACHE_DIR": cache_dir}

    is_mock = os.environ.get("VIRT_VALIDATE_MOCK") == "1"

    # Check for global prerequisite
    prerequisite_file = Path("checks.d/prerequisite.sh")
    if prerequisite_file.exists():
        prereq_result = run_test(prerequisite_file, env, stream_output=False, timeout_secs=args.timeout) if not is_mock else simulate_test(prerequisite_file, stream_output=False, timeout_secs=args.timeout)

        if prereq_result["success"]:
            print(f"{Colors.GREEN}[PASS]{Colors.NC} {format_time(prereq_result['duration'])} {prerequisite_file}")
            print()
        else:
            print(f"{Colors.RED}[FAIL]{Colors.NC} {format_time(prereq_result['duration'])} {prerequisite_file}")
            print(f"\n{Colors.RED}PREREQUISITE FAILURE: Cannot proceed with tests.{Colors.NC}")
            for msg in prereq_result["report_messages"]:
                print(f"    -> {msg}")
            if prereq_result["log"]:
                print("    --- Prerequisite Output ---")
                for line in prereq_result["log"]:
                    print(f"    {line}")
            sys.exit(2)

    test_files = sorted(Path("checks.d").rglob("test*.sh"))

    if args.include:
        patterns = [p.strip() for p in args.include.split(",")]
        test_files = [t for t in test_files if any(p in str(t) for p in patterns)]
    if args.exclude:
        patterns = [p.strip() for p in args.exclude.split(",")]
        test_files = [t for t in test_files if not any(p in str(t) for p in patterns)]
    if args.select:
        test_files = [t for t in test_files if str(t) == args.select]

    if not test_files:
        print("No tests found.")
        sys.exit(0)

    # 2. UI Initialization
    stream_output = bool(args.select and args.verbose and args.output == "human")
    is_tty = args.output == "human" and sys.stdout.isatty() and not stream_output
    
    ui = TerminalUI(test_files, is_tty)
    ui.init_display(test_files)
    
    # 3. Execution
    workers = args.concurrency
    results = []
    failed_count_live = 0
    start_time = time.monotonic()
    start_epoch_ms = int(time.time() * 1000)

    with ThreadPoolExecutor(max_workers=workers) as executor:
        futures = {executor.submit(execute_task, t, env, ui, stream_output, args.timeout, is_mock): t for t in test_files}
        pending = set(futures.keys())
        
        while pending:
            done, pending = wait(pending, timeout=1.0)
            
            for f in done:
                if not f.cancelled():
                    r = f.result()
                    results.append(r)
                    if not r["success"]: failed_count_live += 1

            # Fail-Fast Trigger
            if args.fail_fast and failed_count_live >= args.fail_fast:
                for p in pending: p.cancel()

            ui.update_progress(len(results), time.monotonic() - start_time)

    ui.clear_progress()
    
    # 4. Mark Skipped Tests
    executed_paths = {r["testpath"] for r in results}
    for t in (str(tf) for tf in test_files if str(tf) not in executed_paths):
        ui.update_test(t, f"[{Colors.YELLOW}SKIP{Colors.NC}]")

    # 5. Output Results
    results.sort(key=lambda x: x["testpath"])

    if args.log_dir:
        os.makedirs(args.log_dir, exist_ok=True)
        for r in results:
            name = r["testpath"].replace("checks.d/", "").replace("/", "_")
            with open(os.path.join(args.log_dir, f"{name}.log"), "w") as f:
                f.write("\n".join(r["log"]))

    # Unified Summary Calculation
    skipped_by_test = sum(1 for r in results if r.get("skipped"))
    passed = sum(1 for r in results if r["success"] and not r.get("has_warnings") and not r.get("skipped"))
    warnings = sum(1 for r in results if r["success"] and r.get("has_warnings") and not r.get("skipped"))
    cancelled = sum(1 for r in results if r.get("cancelled"))
    failed = len(results) - passed - warnings - cancelled - skipped_by_test
    skipped = len(test_files) - len(results) + skipped_by_test
    
    summary = f"{Colors.RED}Failed: {failed}{Colors.NC}"
    if warnings > 0: summary += f", {Colors.YELLOW}Warned: {warnings}{Colors.NC}"
    if cancelled > 0: summary += f", {Colors.YELLOW}Cancelled: {cancelled}{Colors.NC}"
    if skipped > 0: summary += f", {Colors.YELLOW}Skipped: {skipped}{Colors.NC}"
    summary += f", {Colors.GREEN}Passed: {passed}{Colors.NC}"
    summary += f", Total: {len(test_files)}"
    
    if args.output == "human":
        print_details(results, args.verbose, skip_log_print=stream_output)
        print("-" * 40)
        print(summary)
        print(f"Total time: {format_time(time.monotonic() - start_time)}")

        # Suggest -v flag if there are failures/warnings and verbose is not set
        if args.verbose == 0 and (failed > 0 or warnings > 0):
            print(f"\n{Colors.YELLOW}Hint: Run with -v to see details of failed/warned checks{Colors.NC}")

        # AI analysis of failures and timeouts (opt-in with --ai-analysis)
        if args.ai_analysis and (failed > 0 or cancelled > 0):
            ask_ai_for_conclusion(results, args.timeout)
    elif args.output == "ctrf":
        stop_epoch_ms = int(time.time() * 1000)
        executed_paths = {r["testpath"] for r in results}

        def ctrf_status(r):
            if r.get("skipped"):
                return "skipped"
            if r["success"]:
                return "passed"
            return "failed"

        def ctrf_suite(testpath):
            parts = testpath.split("/")
            if len(parts) >= 2:
                return parts[1].removesuffix(".d")
            return ""

        ctrf_tests = []
        for r in results:
            name = r["testpath"].removeprefix("checks.d/")
            entry = {
                "name": name,
                "status": ctrf_status(r),
                "duration": int(r["duration"] * 1000),
                "suite": ctrf_suite(r["testpath"]),
            }
            if r["report_messages"]:
                entry["message"] = "; ".join(r["report_messages"])
            if not r["success"] and r["log"]:
                entry["trace"] = "\n".join(r["log"])
            ctrf_tests.append(entry)

        for t in test_files:
            if str(t) not in executed_paths:
                ctrf_tests.append({
                    "name": str(t).removeprefix("checks.d/"),
                    "status": "skipped",
                    "duration": 0,
                    "suite": ctrf_suite(str(t)),
                })

        ctrf_report = {
            "results": {
                "tool": {"name": "virt-cluster-validate"},
                "summary": {
                    "tests": len(test_files),
                    "passed": passed + warnings,
                    "failed": failed + cancelled,
                    "pending": 0,
                    "skipped": skipped,
                    "other": 0,
                    "start": start_epoch_ms,
                    "stop": stop_epoch_ms,
                },
                "tests": ctrf_tests,
            }
        }
        print(json.dumps(ctrf_report, indent=2))

    import shutil
    shutil.rmtree(cache_dir, ignore_errors=True)

    sys.exit(1 if failed_count_live > 0 else 0)

if __name__ == "__main__":
    main()
